<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employer Module</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <!-- Custom CSS -->
    <style>
        /* Global Styles */
body {
    font-family: 'Poppins', sans-serif;
    background-color:linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: #333;
}

/* Gradient Utilities */
.bg-light-gradient {
    background: #b4c7eeff;
}

.text-primary-gradient {
    background:  white;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

/* Navbar */
.navbar-brand {
    font-size: 1.5rem;
    letter-spacing: 1px;
}

.nav-link {
    color: #555;
    font-weight: 500;
    transition: color 0.3s ease;
}

.nav-link:hover, .nav-link.active {
    color: #2575fc;
}

.profile-icon {
    width: 32px;
    height: 32px;
    background-color: #e9ecef;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6a11cb;
}

/* Welcome Card */
.welcome-card {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 15px;
    position: relative;
}

.decorative-circle {
    position: absolute;
    top: -50px;
    right: -50px;
    width: 200px;
    height: 200px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    z-index: 0;
}

/* Dashboard Cards */
.feature-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border-radius: 12px;
    background: #fff;
    border-top: 4px solid transparent; /* Prepare for colored border */
    overflow: hidden;
}

/* Individual Card Colors */
.col-md-6:nth-child(1) .feature-card { border-color: #0d6efd; } /* Primary */
.col-md-6:nth-child(2) .feature-card { border-color: #198754; } /* Success */
.col-md-6:nth-child(3) .feature-card { border-color: #0dcaf0; } /* Info */
.col-md-6:nth-child(4) .feature-card { border-color: #ffc107; } /* Warning */
.col-md-6:nth-child(5) .feature-card { border-color: #dc3545; } /* Danger */

.col-md-6:nth-child(1) .feature-card:hover { background: linear-gradient(to bottom, #fff, #f0f4ff); }
.col-md-6:nth-child(2) .feature-card:hover { background: linear-gradient(to bottom, #fff, #f0fff4); }
.col-md-6:nth-child(3) .feature-card:hover { background: linear-gradient(to bottom, #fff, #f0faff); }
.col-md-6:nth-child(4) .feature-card:hover { background: linear-gradient(to bottom, #fff, #fff9e6); }
.col-md-6:nth-child(5) .feature-card:hover { background: linear-gradient(to bottom, #fff, #fff0f0); }

.feature-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1) !important;
}

.icon-wrapper {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    transition: transform 0.3s ease;
}

.feature-card:hover .icon-wrapper {
    transform: scale(1.1);
}

.section-title {
    position: relative;
    display: inline-block;
    color: #2c3e50;
}

.section-title::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 3px;
    background: linear-gradient(90deg, #6a11cb, #2575fc);
    border-radius: 2px;
}

/* Footer */
.footer {

    background-color: #2c3e50;
    font-size: 0.9rem;
    color: white;
    font-family: 14.4px poppins, sans-serif;
    padding: 48px 0px 16px;
}

.footer h5 {
    color: #fff;
    font-weight: 600;
}

.footer a:hover {
    color: #fff !important;
    text-decoration: underline !important;
}

/* Animations */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.feature-card {
    animation: fadeInUp 0.5s ease-out forwards;
}

.col-md-6:nth-child(1) .feature-card { animation-delay: 0.1s; }
.col-md-6:nth-child(2) .feature-card { animation-delay: 0.2s; }
.col-md-6:nth-child(3) .feature-card { animation-delay: 0.3s; }
.col-md-6:nth-child(4) .feature-card { animation-delay: 0.4s; }
.col-md-6:nth-child(5) .feature-card { animation-delay: 0.5s; }

html, body {
    height: 100%;
}

body {
    display: flex;
    flex-direction: column;
}

.flex-fill {
    flex: 1;
}

    </style>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg shadow-sm sticky-top" style="background:linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
        <div class="container">
            <a class="navbar-brand fw-bold text-uppercase" style="color: white;" href="#">
                <span class="text-primary-gradient">REACT</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/employer" style="color: white;">Home</a>
                        
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/employer/profile-view" style="color: white;">Profile</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/login" style="color: white;">Logout</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link d-flex align-items-center" href="#" aria-expanded="false" style="color: white;">
                            <div class="profile-icon me-2">
                                <i class="fas fa-user"></i>
                            </div>
                            <span class="fw-medium">Employer Admin</span>
                        </a>
                    </li>
                    
                </ul>
            </div>
        </div>
    </nav>
    <main class="flex-fill">

    <!--pushbar-->
    <div id="profilePushbar" class="pushbar">
    <h4>Please Complete Your Profile</h4>
    <a href="/employer/profile">
        <button class="btn btn-primary">Create Profile</button>
    </a>
    </div>

    <!-- Header / Welcome Section -->
    <header class="py-5 bg-light-gradient">
        <div class="container">
            <div class="card border-0 shadow-lg overflow-hidden welcome-card">
                <div class="card-body p-5 d-flex align-items-center justify-content-between position-relative">
                    <div class="z-1">
                        <h1 class="display-5 fw-bold text-white mb-3">Welcome, Employer!👋</h1>
                        <p class="lead text-white-50 mb-4">Manage your recruitment process, view candidates, and
                            schedule interviews efficiently.</p>
                    </div>
                    <div class="d-none d-md-block z-1">
                        <i class="fas fa-building fa-8x text-white-50 opacity-50"></i>
                    </div>
                    <!-- Decorative Circle -->
                    <div class="decorative-circle"></div>
                </div>
            </div>
        </div>
    </header>

    <!-- Dashboard Section -->
    <section id="dashboard" class="py-5">
        <div class="container">
            <h2 class="text-center fw-bold mb-5 section-title">Employer Dashboard</h2>

            <div class="row g-4 justify-content-center">

                <!-- Dashboard Overview Card -->
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm feature-card text-center p-4">
                        <div class="card-body">
                            <div class="icon-wrapper mb-4 bg-primary-subtle text-primary">
                                <i class="fas fa-tachometer-alt fa-2x"></i>
                            </div>
                            <h4 class="card-title fw-bold mb-3">Dashboard</h4>
                            <p class="card-text text-muted">View overall statistics, recent activities, and pending
                                actions at a glance.</p>
                            <a href="/chart" class="stretched-link"></a>
                        </div>
                    </div>
                </div>

                <!-- Candidate Directory Card -->
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm feature-card text-center p-4">
                        <div class="card-body">
                            <div class="icon-wrapper mb-4 bg-success-subtle text-success">
                                <i class="fas fa-users fa-2x"></i>
                            </div>
                            <h4 class="card-title fw-bold mb-3">Candidate Directory</h4>
                            <p class="card-text text-muted">Browse through the complete list of potential candidates for
                                your job openings.</p>
                            <a href="/directory" class="stretched-link"></a>
                        </div>
                    </div>
                </div>

                <!-- Candidate Profile View Card -->
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm feature-card text-center p-4">
                        <div class="card-body">
                            <div class="icon-wrapper mb-4 bg-info-subtle text-info">
                                <i class="fas fa-id-badge fa-2x"></i>
                            </div>
                            <h4 class="card-title fw-bold mb-3">Candidate Profile</h4>
                            <p class="card-text text-muted">View detailed profiles, resumes, and portfolios of specific
                                candidates.</p>
                            <a href="/profile-view" class="stretched-link"></a>
                        </div>
                    </div>
                </div>
    </main>

    <!-- Footer -->
    <footer class="footer text-white pt-5 pb-3">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <h5 class="fw-bold mb-3">About Us</h5>
                    <p class="small text-white-50">Dedicated to empowering organizations and creating sustainable
                        community impact through strategic development and capacity building.</p>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h5 class="fw-bold mb-3">Quick Links</h5>
                    <ul class="list-unstyled small">
                        <li><a href="#" class="text-white-50 text-decoration-none">Home</a></li>
                        <li><a href="#" class="text-white-50 text-decoration-none">Services</a></li>
                        <li><a href="#" class="text-white-50 text-decoration-none">About</a></li>
                        <li><a href="#" class="text-white-50 text-decoration-none">Contact</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h5 class="fw-bold mb-3">Services</h5>
                    <ul class="list-unstyled small">
                        <li><a href="#" class="text-white-50 text-decoration-none">Strategic Planning</a></li>
                        <li><a href="#" class="text-white-50 text-decoration-none">Capacity Building</a></li>
                        <li><a href="#" class="text-white-50 text-decoration-none">Impact Assessment</a></li>
                        <li><a href="#" class="text-white-50 text-decoration-none">Organizational Development</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h5 class="fw-bold mb-3">Contact</h5>
                    <ul class="list-unstyled small text-white-50">
                        <li><i class="fas fa-envelope me-2"></i> info@example.com</li>
                        <li><i class="fas fa-phone me-2"></i> +91 123 456 7890</li>
                        <li><i class="fas fa-map-marker-alt me-2"></i> City, State, Country</li>
                    </ul>
                </div>
            </div>
            <hr class="border-secondary mt-4 mb-3">
            <div class="text-center small text-white-50">
                &copy; 2024 REACT Organization. All rights reserved.
            </div>
        </div>
    </footer>


    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <% if (showPushbar) { %>
<script>
  window.onload = function() {
    document.getElementById("profilePushbar").classList.add("active");
  };
</script>
<% } %>

</body>
</html>
