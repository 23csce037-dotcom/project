<!DOCTYPE html>
<html>


<head>
    <title>PWD Dashboard - REACT</title>
    <style>
        body {
            font-family: "Segoe UI", Tahoma, Geneva, Verdana;
            background: #b4c7eeff;
            margin: 0;
        }


        /* ===== Header / Navbar ===== */
        header {
            background: linear-gradient(135deg, #667eea, #764ba2);
            padding: 0.5rem 0;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        }


        nav {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            padding: 10px 20px;
        }


        .logo {
            font-size: 1.5rem;
            font-weight: bold;
            color: #f2f4f7ff;
        }


        .nav-links {
            margin-left: auto;
            display: flex;
            gap: 30px;
            list-style: none;
        }


        .nav-links a {
            text-decoration: none;
            color: white;
            font-weight: 500;
            font-size: 16px;
        }


        /* ===== Dashboard Layout ===== */
        .dashboard-container {
            max-width: 1200px;
            margin: 40px auto;
            padding: 20px;
        }


        h2 {
            color: #2c5aa0;
            margin-bottom: 10px;
        }


        .welcome {
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            margin-bottom: 30px;
        }


        /* ===== Cards ===== */
        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }


        .card {
            background: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s;
        }


        .card:hover {
            transform: translateY(-5px);
        }


        .card h3 {
            color: #2c5aa0;
            margin-bottom: 10px;
        }


        .card p {
            color: #555;
            font-size: 14px;
            margin-bottom: 15px;
        }


        .btn {
            display: inline-block;
            padding: 10px 16px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-size: 14px;
        }


        /* ===== Footer ===== */
        footer {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: #f2f4f7ff;
            text-align: center;
            padding: 20px 0;
            margin-top: 40px;
        }
    </style>
</head>


<body>


    <!-- ===== Header ===== -->
    <header>
        <nav>
            <div class="logo">REACT</div>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/pwd">Dashboard</a></li>
                <li><a href="/logout">Logout</a></li>
            </ul>
        </nav>
    </header>


    <!-- ===== Dashboard Content ===== -->
    <div class="dashboard-container">


        <div class="welcome">
            <h2>Welcome, PWD User 👋</h2>
            <p>
                Manage your profile, upload resume, explore jobs, employers and
                scholarships suitable for you.
            </p>
        </div>


        <div class="card-grid">


            <div class="card">
                <h3>My Profile</h3>
                <p>
                    View and update personal details such as name, age, DOB,
                    disability type, percentage and location.
                </p>
                 <a href="/profile/view" class="btn">View /Update</a>
            </div>


            <div class="card">
                <h3>Resume & Skills</h3>
                <p>
                    Upload resume, add qualification, experience level
                    and technical skills.
                </p>
                <a href="#" class="btn">Manage Resume</a>
            </div>


            <div class="card">
                <h3>Job Opportunities</h3>
                <p>
                    View jobs based on your skills, job expectations
                    and preferred location.
                </p>
                <a href="#" class="btn">View Jobs</a>
            </div>


            <div class="card">
                <h3>Employers</h3>
                <p>
                    Explore inclusive employers who are hiring PWD candidates.
                </p>
                <a href="#" class="btn">View Employers</a>
            </div>


            <div class="card">
                <h3>Scholarships</h3>
                <p>
                    Check available scholarships and financial support
                    for PWD students.
                </p>
                <a href="#" class="btn">View Scholarships</a>
            </div>


        </div>


    </div>


    <!-- ===== Footer ===== -->
    <footer>
        © 2026 REACT | PWD Dashboard
    </footer>


</body>


</html>